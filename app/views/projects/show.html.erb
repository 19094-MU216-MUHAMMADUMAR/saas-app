<div class="container-fluid">
  <div class="row">
    <div class="col-md-12">
      <div class="d-flex justify-content-between align-items-start mb-4">
        <div>
          <h1 class="h3"><%= @project.name %></h1>
          <span class="badge bg-<%= @project.status == 'active' ? 'success' : @project.status == 'completed' ? 'primary' : 'secondary' %> fs-6">
            <%= @project.status.titleize %>
          </span>
        </div>
        <div>
          <%= link_to "Back to Projects", projects_path, class: "btn btn-secondary me-2" %>
          <% if current_user.admin? %>
            <%= link_to "Edit Project", edit_project_path(@project), class: "btn btn-primary" %>
          <% end %>
        </div>
      </div>
      
      <div class="row">
        <div class="col-md-8">
          <!-- Project Details -->
          <div class="card mb-4">
            <div class="card-header">
              <h5 class="mb-0">Project Details</h5>
            </div>
            <div class="card-body">
              <% if @project.description.present? %>
                <p class="mb-3"><%= simple_format(@project.description) %></p>
              <% else %>
                <p class="text-muted mb-3">No description provided.</p>
              <% end %>
              
              <div class="row">
                <div class="col-md-6">
                  <strong>Created:</strong> <%= @project.created_at.strftime("%B %d, %Y") %>
                </div>
                <div class="col-md-6">
                  <% if @project.due_date %>
                    <strong>Due Date:</strong> 
                    <%= @project.due_date.strftime("%B %d, %Y") %>
                    <% if @project.due_date < Date.current && @project.status != 'completed' %>
                      <span class="badge bg-danger ms-2">Overdue</span>
                    <% end %>
                  <% else %>
                    <strong>Due Date:</strong> <span class="text-muted">Not set</span>
                  <% end %>
                </div>
              </div>
            </div>
          </div>
          
          <!-- Project Files -->
          <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
              <h5 class="mb-0">Project Files</h5>
              <span class="badge bg-primary"><%= @project.files.count %> files</span>
            </div>
            <div class="card-body">
              <% if @project.files.any? %>
                <div class="list-group list-group-flush">
                  <% @project.files.each do |file| %>
                    <div class="list-group-item d-flex justify-content-between align-items-center">
                      <div>
                        <i class="bi bi-file-earmark-fill me-2"></i>
                        <%= file.filename %>
                        <small class="text-muted d-block">
                          <%= number_to_human_size(file.byte_size) %> • 
                          Uploaded <%= file.created_at.strftime("%b %d, %Y") %>
                        </small>
                      </div>
                      <div>
                        <%= link_to "Download", rails_blob_path(file, disposition: "attachment"), 
                            class: "btn btn-sm btn-outline-primary me-2" %>
                        <% if current_user.admin? %>
                          <%= link_to remove_file_project_path(@project, file.id), 
                              method: :delete, 
                              confirm: "Are you sure you want to delete this file?",
                              class: "btn btn-sm btn-outline-danger" do %>
                            <i class="bi bi-trash"></i>
                          <% end %>
                        <% end %>
                      </div>
                    </div>
                  <% end %>
                </div>
              <% else %>
                <div class="text-center py-4">
                  <i class="bi bi-file-earmark-x fs-1 text-muted"></i>
                  <h6 class="mt-3 text-muted">No files uploaded</h6>
                  <p class="text-muted">Files will appear here when uploaded to this project</p>
                </div>
              <% end %>
            </div>
          </div>
        </div>
        
        <!-- Sidebar -->
        <div class="col-md-4">
          <!-- Project Actions -->
          <div class="card mb-4">
            <div class="card-header">
              <h6 class="mb-0">Project Actions</h6>
            </div>
            <div class="card-body">
              <div class="d-grid gap-2">
                <% if current_user.admin? %>
                  <%= link_to edit_project_path(@project), class: "btn btn-outline-primary" do %>
                    <i class="bi bi-pencil me-2"></i>Edit Project
                  <% end %>
                  
                  <%= link_to @project, method: :delete, 
                      confirm: "Are you sure you want to delete this project? This action cannot be undone.",
                      class: "btn btn-outline-danger" do %>
                    <i class="bi bi-trash me-2"></i>Delete Project
                  <% end %>
                <% end %>
                
                <%= link_to projects_path, class: "btn btn-outline-secondary" do %>
                  <i class="bi bi-arrow-left me-2"></i>Back to Projects
                <% end %>
              </div>
            </div>
          </div>
          
          <!-- Project Statistics -->
          <div class="card">
            <div class="card-header">
              <h6 class="mb-0">Project Statistics</h6>
            </div>
            <div class="card-body">
              <div class="row text-center">
                <div class="col-6">
                  <div class="border-end">
                    <h4 class="text-primary"><%= @project.files.count %></h4>
                    <small class="text-muted">Files</small>
                  </div>
                </div>
                <div class="col-6">
                  <h4 class="text-success">
                    <%= time_ago_in_words(@project.created_at) %>
                  </h4>
                  <small class="text-muted">Age</small>
                </div>
              </div>
              
              <hr>
              
              <div class="small">
                <div class="d-flex justify-content-between mb-2">
                  <span>Status:</span>
                  <span class="fw-bold text-capitalize"><%= @project.status %></span>
                </div>
                <div class="d-flex justify-content-between mb-2">
                  <span>Last Updated:</span>
                  <span><%= @project.updated_at.strftime("%b %d, %Y") %></span>
                </div>
                <% if @project.files.any? %>
                  <div class="d-flex justify-content-between">
                    <span>Total File Size:</span>
                    <span><%= number_to_human_size(@project.files.sum(&:byte_size)) %></span>
                  </div>
                <% end %>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
