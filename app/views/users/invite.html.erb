<div class="container">
  <div class="row justify-content-center">
    <div class="col-md-6">
      <div class="card">
        <div class="card-header">
          <h4 class="mb-0">Invite Team Member</h4>
        </div>
        <div class="card-body">
          <%= form_with url: send_invitation_users_path, method: :post, local: true do |form| %>
            <% if @user && @user.errors.any? %>
              <div class="alert alert-danger">
                <h6>Please fix the following errors:</h6>
                <ul class="mb-0">
                  <% @user.errors.full_messages.each do |message| %>
                    <li><%= message %></li>
                  <% end %>
                </ul>
              </div>
            <% end %>

            <div class="mb-3">
              <%= form.label :email, class: "form-label" %>
              <%= form.email_field :email, class: "form-control", placeholder: "Enter email address", required: true %>
              <div class="form-text">
                An invitation email will be sent to this address
              </div>
            </div>

            <div class="mb-3">
              <%= form.label :first_name, class: "form-label" %>
              <%= form.text_field :first_name, class: "form-control", placeholder: "First name" %>
            </div>

            <div class="mb-3">
              <%= form.label :last_name, class: "form-label" %>
              <%= form.text_field :last_name, class: "form-control", placeholder: "Last name" %>
            </div>

            <div class="mb-3">
              <%= form.label :role, class: "form-label" %>
              <%= form.select :role, 
                  options_for_select([
                    ['Employee', 'employee'],
                    ['Administrator', 'admin']
                  ], 'employee'), 
                  {}, 
                  { class: "form-select" } %>
              <div class="form-text">
                <strong>Employee:</strong> Can view and manage projects<br>
                <strong>Administrator:</strong> Full access including user management and billing
              </div>
            </div>

            <div class="d-flex justify-content-between">
              <%= link_to "Cancel", users_path, class: "btn btn-secondary" %>
              <%= form.submit "Send Invitation", class: "btn btn-primary" %>
            </div>
          <% end %>
        </div>
      </div>
      
      <!-- Info Card -->
      <div class="card mt-4">
        <div class="card-header">
          <h6 class="mb-0"><i class="bi bi-info-circle"></i> How Invitations Work</h6>
        </div>
        <div class="card-body">
          <ol class="mb-0">
            <li>Enter the team member's email address and details</li>
            <li>An invitation email will be sent automatically</li>
            <li>They'll receive a link to join your organization</li>
            <li>Once they accept, they'll have access based on their role</li>
          </ol>
        </div>
      </div>
    </div>
  </div>
</div>
