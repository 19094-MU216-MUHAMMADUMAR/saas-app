<div class="container-fluid">
  <div class="row">
    <div class="col-md-12">
      <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3">Projects</h1>
        <% if current_user.admin? %>
          <%= link_to "New Project", new_project_path, class: "btn btn-primary" %>
        <% end %>
      </div>
      
      <% if @projects.any? %>
        <div class="row">
          <% @projects.each do |project| %>
            <div class="col-md-4 mb-4">
              <div class="card h-100">
                <div class="card-body">
                  <div class="d-flex justify-content-between align-items-start mb-2">
                    <h5 class="card-title"><%= project.name %></h5>
                    <span class="badge bg-<%= project.status == 'active' ? 'success' : project.status == 'completed' ? 'primary' : 'secondary' %>">
                      <%= project.status.titleize %>
                    </span>
                  </div>
                  
                  <% if project.description.present? %>
                    <p class="card-text text-muted"><%= truncate(project.description, length: 100) %></p>
                  <% end %>
                  
                  <div class="mb-3">
                    <% if project.due_date %>
                      <small class="text-muted">
                        <i class="bi bi-calendar-event"></i>
                        Due: <%= project.due_date.strftime("%b %d, %Y") %>
                        <% if project.due_date < Date.current && project.status != 'completed' %>
                          <span class="text-danger">(Overdue)</span>
                        <% end %>
                      </small>
                    <% end %>
                  </div>
                  
                  <% if project.files.any? %>
                    <div class="mb-3">
                      <small class="text-muted">
                        <i class="bi bi-paperclip"></i>
                        <%= pluralize(project.files.count, 'file') %>
                      </small>
                    </div>
                  <% end %>
                </div>
                
                <div class="card-footer bg-transparent">
                  <div class="d-flex justify-content-between">
                    <%= link_to "View", project, class: "btn btn-sm btn-outline-primary" %>
                    <% if current_user.admin? %>
                      <div>
                        <%= link_to "Edit", edit_project_path(project), class: "btn btn-sm btn-outline-secondary" %>
                        <%= link_to "Delete", project, method: :delete, 
                            confirm: "Are you sure?", 
                            class: "btn btn-sm btn-outline-danger" %>
                      </div>
                    <% end %>
                  </div>
                </div>
              </div>
            </div>
          <% end %>
        </div>
        
        <!-- Pagination could be added here if needed -->
        
      <% else %>
        <div class="text-center py-5">
          <i class="bi bi-folder-x fs-1 text-muted"></i>
          <h4 class="mt-3 text-muted">No projects yet</h4>
          <p class="text-muted">Create your first project to get started</p>
          <% if current_user.admin? %>
            <%= link_to "Create Project", new_project_path, class: "btn btn-primary btn-lg" %>
          <% end %>
        </div>
      <% end %>
      
      <!-- Project Limits Info for Admins -->
      <% if current_user.admin? && current_organization.project_limit %>
        <div class="alert alert-info mt-4">
          <i class="bi bi-info-circle"></i>
          You have used <%= @projects.count %> of <%= current_organization.project_limit %> projects allowed on your <%= current_organization.subscription_plan.titleize %> plan.
          <% if @projects.count >= current_organization.project_limit %>
            <%= link_to "Upgrade Plan", subscription_path, class: "btn btn-sm btn-primary ms-2" %>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</div>
