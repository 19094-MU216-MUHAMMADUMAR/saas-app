<div class="container">
  <div class="row justify-content-center">
    <div class="col-md-8">
      <div class="card">
        <div class="card-header">
          <h4 class="mb-0">Create New Project</h4>
        </div>
        <div class="card-body">
          <%= form_with model: @project, local: true, multipart: true do |form| %>
            <% if @project.errors.any? %>
              <div class="alert alert-danger">
                <h6>Please fix the following errors:</h6>
                <ul class="mb-0">
                  <% @project.errors.full_messages.each do |message| %>
                    <li><%= message %></li>
                  <% end %>
                </ul>
              </div>
            <% end %>

            <div class="mb-3">
              <%= form.label :name, class: "form-label" %>
              <%= form.text_field :name, class: "form-control", placeholder: "Enter project name" %>
            </div>

            <div class="mb-3">
              <%= form.label :description, class: "form-label" %>
              <%= form.text_area :description, class: "form-control", rows: 4, placeholder: "Describe your project..." %>
            </div>

            <div class="row">
              <div class="col-md-6">
                <div class="mb-3">
                  <%= form.label :status, class: "form-label" %>
                  <%= form.select :status, 
                      options_for_select([
                        ['Planning', 'planning'],
                        ['Active', 'active'],
                        ['On Hold', 'on_hold'],
                        ['Completed', 'completed']
                      ], @project.status), 
                      { prompt: 'Select status' }, 
                      { class: "form-select" } %>
                </div>
              </div>
              
              <div class="col-md-6">
                <div class="mb-3">
                  <%= form.label :due_date, class: "form-label" %>
                  <%= form.date_field :due_date, class: "form-control" %>
                </div>
              </div>
            </div>

            <div class="mb-3">
              <%= form.label :files, "Project Files", class: "form-label" %>
              <%= form.file_field :files, multiple: true, class: "form-control", accept: ".pdf,.doc,.docx,.txt,.jpg,.jpeg,.png,.gif" %>
              <div class="form-text">
                You can upload multiple files. Supported formats: PDF, DOC, DOCX, TXT, JPG, JPEG, PNG, GIF
              </div>
            </div>

            <div class="d-flex justify-content-between">
              <%= link_to "Cancel", projects_path, class: "btn btn-secondary" %>
              <%= form.submit "Create Project", class: "btn btn-primary" %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
