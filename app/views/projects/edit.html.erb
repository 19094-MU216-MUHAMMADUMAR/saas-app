<div class="container">
  <div class="row justify-content-center">
    <div class="col-md-8">
      <div class="card">
        <div class="card-header">
          <h4 class="mb-0">Edit Project</h4>
        </div>
        <div class="card-body">
          <%= form_with model: @project, local: true, multipart: true do |form| %>
            <% if @project.errors.any? %>
              <div class="alert alert-danger">
                <h6>Please fix the following errors:</h6>
                <ul class="mb-0">
                  <% @project.errors.full_messages.each do |message| %>
                    <li><%= message %></li>
                  <% end %>
                </ul>
              </div>
            <% end %>

            <div class="mb-3">
              <%= form.label :name, class: "form-label" %>
              <%= form.text_field :name, class: "form-control" %>
            </div>

            <div class="mb-3">
              <%= form.label :description, class: "form-label" %>
              <%= form.text_area :description, class: "form-control", rows: 4 %>
            </div>

            <div class="row">
              <div class="col-md-6">
                <div class="mb-3">
                  <%= form.label :status, class: "form-label" %>
                  <%= form.select :status, 
                      options_for_select([
                        ['Planning', 'planning'],
                        ['Active', 'active'],
                        ['On Hold', 'on_hold'],
                        ['Completed', 'completed']
                      ], @project.status), 
                      {}, 
                      { class: "form-select" } %>
                </div>
              </div>
              
              <div class="col-md-6">
                <div class="mb-3">
                  <%= form.label :due_date, class: "form-label" %>
                  <%= form.date_field :due_date, class: "form-control" %>
                </div>
              </div>
            </div>

            <!-- Existing Files -->
            <% if @project.files.any? %>
              <div class="mb-3">
                <label class="form-label">Current Files</label>
                <div class="border rounded p-3">
                  <% @project.files.each do |file| %>
                    <div class="d-flex justify-content-between align-items-center mb-2">
                      <div>
                        <i class="bi bi-file-earmark-fill me-2"></i>
                        <%= file.filename %>
                        <small class="text-muted">(<%= number_to_human_size(file.byte_size) %>)</small>
                      </div>
                      <%= link_to remove_file_project_path(@project, file.id), 
                          method: :delete, 
                          confirm: "Are you sure you want to delete this file?",
                          class: "btn btn-sm btn-outline-danger" do %>
                        <i class="bi bi-trash"></i> Remove
                      <% end %>
                    </div>
                  <% end %>
                </div>
              </div>
            <% end %>

            <div class="mb-3">
              <%= form.label :files, "Add New Files", class: "form-label" %>
              <%= form.file_field :files, multiple: true, class: "form-control", accept: ".pdf,.doc,.docx,.txt,.jpg,.jpeg,.png,.gif" %>
              <div class="form-text">
                Upload additional files. Supported formats: PDF, DOC, DOCX, TXT, JPG, JPEG, PNG, GIF
              </div>
            </div>

            <div class="d-flex justify-content-between">
              <%= link_to "Cancel", @project, class: "btn btn-secondary" %>
              <%= form.submit "Update Project", class: "btn btn-primary" %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
